\ProvidesPackage{main}

\RequirePackage{luatexja-fontspec}
\RequirePackage{geometry}
\RequirePackage{xcolor}

\definecolor{teal}{RGB}{0,128,128}
\definecolor{powderblue}{RGB}{176,224,230}
\definecolor{darkslateblue}{RGB}{72,61,139}
\definecolor{darkslategray}{RGB}{47,79,79}
\definecolor{lightcyan}{RGB}{224,255,255}

% ===== 欧文フォント =====
\setmainfont[
    Path = ./fonts/,
    Extension = .otf,
    UprightFont = *-M,      % 標準（普通体）
    BoldFont    = *-B,      % 太字
    LightFont   = *-L,      % 細字
    DemiBoldFont= *-DB,     % 中太（任意）
    BlackFont   = *-D,      % 最太字
    JFM = jlreq,
]{FOT-TsukuOldGothicStd}

% ===== 日本語フォント（ファイル指定） =====
\setmainjfont[
  Path = ./fonts/,
  Extension = .otf,
  UprightFont = *-L,
  BoldFont = *-B,
  JFM = jlreq
]{FOT-UDMinchoPr6}

\newjfontfamily\titlejfont[
    Path = ./fonts/,
    Extension = .otf,
    UprightFont = *-M,      % 標準（普通体）
    BoldFont    = *-B,      % 太字
    LightFont   = *-L,      % 細字
    DemiBoldFont= *-DB,     % 中太（任意）
    BlackFont   = *-D,      % 最太字
    JFM = jlreq,
]{FOT-TsukuOldGothicStd}

\geometry{
    top=22mm,          % ページ上部余白
    headheight=28pt,   % ヘッダーの高さ
    headsep=5mm,       % ヘッダーと本文の間隔
    bottom=15mm,
    left=12mm,
    right=12mm
}

\RequirePackage{titlesec}
\titlespacing*{\chapter}{0pt}{0pt}{10pt}

\titleformat{\chapter}[block]
  {\fontsize{25pt}{10pt}\titlejfont\bfseries\filleft\selectfont}
  {}
  {0pt}
  {}
  [\vspace{0.5em}\hrule
   \vspace{0.3em}{\Large\selectfont \filleft 第 \thechapter 章}] % 装飾

\renewcommand{\thechapter}{\arabic{chapter}}


% ===== 累計セクションカウンタ =====
\newcounter{lecture} % 「第○講」用

% セクション呼び出し前にカウンタを増やす
\usepackage{etoolbox}
\preto\section{\stepcounter{lecture}}

% セクション番号を「第○講」にする
\renewcommand{\thesection}{第\arabic{lecture}講}

\preto\section{\clearpage}

% section
\titleformat{\section}[block]
{}{}{0pt}
{
    \colorbox{teal}{\begin{picture}(0,15)\end{picture}}
    \hspace{0pt}
    \normalfont \fontsize{18pt}{32pt}\titlejfont\bfseries \thesection
    \hspace{.6em}
}
[
    \begin{picture}(100,0)
    \put(3,30){\color{teal}\line(1,0){400}}
    \end{picture}
    \\
    \vspace{-50pt}
]

\counterwithin{subsection}{section}

\renewcommand{\thesubsection}{\arabic{subsection}}

% subsection 書式
\titleformat{\subsection}[block]
  {\normalfont\fontsize{18pt}{28pt}}
  {\thesubsection.}
  {.4em}
  {}
  []

\newcommand{\emp}[1]{{\titlejfont\bfseries #1}}